# Fichier d'exemple pour les variables d'environnement Docker Compose
# Copiez ce fichier vers .docker-compose.env pour la production
# Utilisez: docker-compose --env-file .docker-compose.env -f docker-compose.prod.yml up

# Base de données
DB_USERNAME=unikin_user
DB_PASSWORD=changez-moi-en-production
DB_DATABASE=internet_access
DB_PORT=5432

# Backend
BACKEND_PORT=4000
JWT_SECRET=changez-moi-en-production-secret-jwt-super-securise
NODE_ENV=production

# MikroTik
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=votre-mot-de-passe-mikrotik

# Frontend
FRONTEND_PORT=80
FRONTEND_URL=https://votre-domaine.com

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM=noreply@unikin.cd

# Application
APP_NAME=Club Internet Access UNIKIN
