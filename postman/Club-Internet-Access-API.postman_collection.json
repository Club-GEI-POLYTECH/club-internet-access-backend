{
  "info": {
    "name": "Club Internet Access API",
    "description": "Vente de tickets Wi‑Fi (import CSV Mikhmon) — auth, tickets, paiements, dashboard, utilisateurs.\n\nVariables : `baseUrl` (ex. http://localhost:4000), `token` (rempli après Login). Optionnel : `userId`, `paymentId`, `ticketId`, `typeId`, `transactionId`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "typeId", "value": "" },
    { "key": "transactionId", "value": "MTN123456" },
    { "key": "merchantReference", "value": "" }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api"
          }
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register request (code email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@student.unikin.cd\",\n  \"password\": \"password123\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Test\",\n  \"phone\": \"+243900000000\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register/request"
          }
        },
        {
          "name": "Register verify (JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@student.unikin.cd\",\n  \"code\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register/verify"
          }
        },
        {
          "name": "Register resend code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@student.unikin.cd\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register/resend"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@unikin.cd\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@unikin.cd\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-from-email\",\n  \"newPassword\": \"newPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@unikin.cd\",\n  \"password\": \"password123\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"role\": \"agent\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"phone\": \"+243999999999\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "List Tickets (by status)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets?status=available"
          }
        },
        {
          "name": "List Available Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/available"
          }
        },
        {
          "name": "Ticket Types",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/types"
          }
        },
        {
          "name": "Get Ticket Type by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/types/{{typeId}}"
          }
        },
        {
          "name": "Tickets by Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/type/{{typeId}}"
          }
        },
        {
          "name": "Get Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}"
          }
        },
        {
          "name": "Purchase Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var json = pm.response.json();",
                  "  if (json.payment && json.payment.id) {",
                  "    pm.collectionVariables.set('paymentId', json.payment.id);",
                  "  }",
                  "  if (json.ticket && json.ticket.id) {",
                  "    pm.collectionVariables.set('ticketId', json.ticket.id);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketId\": \"{{ticketId}}\",\n  \"phoneNumber\": \"+243900000000\",\n  \"method\": \"mobile_money\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets/purchase"
          }
        },
        {
          "name": "Reserve Ticket",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}/reserve"
          }
        },
        {
          "name": "Release Ticket",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}/release"
          }
        },
        {
          "name": "Webhook Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"status\": \"completed\",\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets/webhook/payment"
          }
        },
        {
          "name": "Admin - Import Tickets (CSV)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/tickets/admin/import"
          }
        },
        {
          "name": "Admin - Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tickets/admin/stats"
          }
        },
        {
          "name": "Admin - Delete Ticket",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tickets/admin/{{ticketId}}"
          }
        }
      ]
    },
    {
      "name": "Admin Tickets (alt path)",
      "description": "Même logique que `/api/tickets/admin/*` pour les frontends qui appellent `/api/admin/tickets/*`.",
      "item": [
        {
          "name": "Import Tickets (CSV)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/admin/tickets/import"
          }
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/tickets/stats"
          }
        },
        {
          "name": "Delete Ticket",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Paiements : achat `POST /tickets/purchase`, KELPAY `POST /payments/initiate` (polling serveur checktransaction), complétion admin.",
      "item": [
        {
          "name": "KELPAY Initiate (Mobile Money)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.paymentId) { pm.collectionVariables.set('paymentId', json.paymentId); }",
                  "if (json.merchantReference) { pm.collectionVariables.set('merchantReference', json.merchantReference); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketId\": \"{{ticketId}}\",\n  \"phoneNumber\": \"+243900000000\",\n  \"amount\": 1000,\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/initiate"
          }
        },
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get Payment by Transaction ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments/transaction/{{transactionId}}"
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}"
          }
        },
        {
          "name": "Complete Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/complete"
          }
        },
        {
          "name": "Update Payment Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"failed\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/status"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "My Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/my-stats"
          }
        },
        {
          "name": "Stats (Admin/Agent)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/stats"
          }
        },
        {
          "name": "Charts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/charts?days=30"
          }
        }
      ]
    }
  ]
}
