            "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Flux **KELPAY** : initiate → verify → confirm ; cancel si abandon. **Hors Kelpay** : `POST /tickets/purchase` (`card`, etc. — plus d’espèces). Callback Kelpay en parallèle. **Admin** : `POST /payments/:id/complete` si besoin.",
      "item": [
        {
          "name": "KELPAY (3 étapes + cancel)",
          "description": "Ordre : 1) Initiate — 2) après validation sur le téléphone, Verify (répéter si pending) — 3) Confirm. **Cancel** : abandon avant confirm (`pending`/`processing`). Variables : token, userId, ticketId, amount = prix du type.",
          "item": [
            {
              "name": "1. Initiate",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var json = pm.response.json();",
                      "if (json.paymentId) { pm.collectionVariables.set('paymentId', json.paymentId); }",
                      "if (json.merchantReference) { pm.collectionVariables.set('merchantReference', json.merchantReference); }"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ticketId\": \"{{ticketId}}\",\n  \"phoneNumber\": \"+243900000000\",\n  \"amount\": 1000,\n  \"userId\": \"{{userId}}\"\n}"
                },
                "url": "{{baseUrl}}/api/payments/initiate"
              }
            },
            {
              "name": "2. Verify (checktransaction ×1)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/payments/{{paymentId}}/kelpay/verify"
              }
            },
            {
              "name": "3. Confirm (finaliser + ticket)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/payments/{{paymentId}}/kelpay/confirm"
              }
            },
            {
              "name": "Cancel (abandon avant confirm)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": "{{baseUrl}}/api/payments/{{paymentId}}/kelpay/cancel"
              }
            }
          ]
        },
        {
          "name": "List Payments",
          "description": "Paginé `{ data, meta }`. Query : `page`, `limit`, `status`, `method`, `search`, `createdById` (admin/agent).",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/payments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Payment by Transaction ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments/transaction/{{transactionId}}"
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}"
          }
        },
        {
          "name": "Complete Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/complete"
          }
        },
        {
          "name": "Update Payment Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"failed\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/status"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "description": "**Rôles** : `GET …/stats` et `GET …/charts` exigent un JWT **admin** ou **agent**. `GET …/my-stats` : tout utilisateur authentifié.\n\n**Stats** : agrégats + `tickets.byTicketType` (par forfait) + `recent.payments`, `recent.users`, `recent.tickets`.",
      "item": [
        {
          "name": "My Stats",
          "description": "Compteur de paiements liés au compte connecté (`{ paymentsCount }`). JWT requis.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/my-stats"
          }
        },
        {
          "name": "Stats (Admin/Agent)",
          "description": "Statistiques globales. Corps typique :\n\n- `payments` : `total`, `completed` (payés = success+completed), `pending` (PENDING seul), `processing`, `cancelled`, `failed` (failed+expired), `revenue` — `recent.payments[].amount` est un **number**\n- `tickets` : `total`, `available`, `sold`, `reserved`, `revenue`, **`byTicketType`** (tableau par forfait : `ticketTypeId`, `name`, `price`, `total`, `available`, `sold`, `reserved`, `revenue`)\n- `users` : `total`, `active`, `inactive`, `byRole`\n- `recent.payments` : 15 derniers (relation `ticket` via `ticketId`, mot de passe masqué)\n- `recent.users` : 15 derniers comptes (sans mot de passe)\n- `recent.tickets` : 15 derniers tickets importés (sans mot de passe Wi‑Fi)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/stats"
          }
        },
        {
          "name": "Charts",
          "description": "Séries temporelles : `payments` (par jour : `date`, `count`, `revenue`) et `ticketsSold` (`date`, `sold`). Query `days` optionnel (défaut API : 7 ; ici exemple 30).",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/charts?days=30"
          }
        }
      ]
    }
  ]
}
