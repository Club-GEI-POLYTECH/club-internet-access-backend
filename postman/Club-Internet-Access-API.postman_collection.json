        {
          "name": "My Tickets (paginated)",
          "description": "JWT requis — tickets liés aux paiements de l'utilisateur. `{ data, meta }`. Query : `page`, `limit`, `status` (ex. sold).",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tickets/me?page=1&limit=10&status=sold",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets", "me"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "sold" }
              ]
            }
          }
        },
        {
          "name": "Purchase Ticket",
          "description": "Réservation + paiement `pending`. `method` : `mobile_money` ou `card` (les espèces ne sont plus supportées). Pour Mobile Money Kelpay, préférer le dossier **KELPAY** (`initiate`…), pas ce corps avec `mobile_money` en parallèle.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var json = pm.response.json();",
                  "  if (json.payment && json.payment.id) {",
                  "    pm.collectionVariables.set('paymentId', json.payment.id);",
                  "  }",
                  "  if (json.ticket && json.ticket.id) {",
                  "    pm.collectionVariables.set('ticketId', json.ticket.id);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketId\": \"{{ticketId}}\",\n  \"phoneNumber\": \"+243900000000\",\n  \"method\": \"card\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets/purchase"
          }
        },
        {
          "name": "Webhook Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Payment-Webhook-Secret", "value": "{{paymentWebhookSecret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"status\": \"completed\",\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/tickets/webhook/payment"
          }
        },
        {
          "name": "Admin - Import Tickets (CSV)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/tickets/admin/import"
          }
        },
        {
          "name": "Admin - Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tickets/admin/stats"
          }
        },
        {
          "name": "Admin - Delete Ticket",
