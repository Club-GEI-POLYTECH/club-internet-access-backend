{
  "info": {
    "name": "Club Internet Access API",
    "description": "API REST pour la gestion d'accès Wi-Fi via MikroTik RouterOS - Club Internet Access UNIKIN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
