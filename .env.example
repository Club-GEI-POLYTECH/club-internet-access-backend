# =============================================================================
# Copier vers .env :   cp .env.example .env
# Ne jamais committer le fichier .env (déjà dans .gitignore).
# =============================================================================

# --- Base de données (obligatoire, format PostgreSQL URI) ---
# Exemple local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internet_access
DATABASE_URL=

# --- JWT (obligatoire) ---
JWT_SECRET=change-me-long-random-string-for-local-dev

# --- Chiffrement des mots de passe tickets (obligatoire — min. 32 caractères recommandé) ---
TICKET_ENCRYPTION_KEY=change-me-32-chars-min-ticket-encryption!!

# --- Application ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APP_NAME=Club Internet Access UNIKIN

# --- Prix tickets (CDF) ---
TICKET_PRICE_24H=1000
TICKET_PRICE_7D=3500
TICKET_PRICE_30D=9000

# --- Emails : Resend (recommandé en prod) OU SMTP ---
# Si RESEND_API_KEY est défini, tous les envois passent par l’API Resend (reset mot de passe, code inscription).
# L’adresse d’expéditeur doit être autorisée dans le dashboard Resend (domaine vérifié).
# En dev sans clé : MailHog / SMTP ci-dessous.
RESEND_API_KEY=
# Optionnel : expéditeur Resend (sinon SMTP_FROM est utilisé), ex. onboarding@resend.dev en test ou noreply@votredomaine.com
RESEND_FROM=

# En local, un relais SMTP de test (ex. MailHog sur localhost:1025) ou votre serveur réel
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@unikin.cd

# --- Inscription par email (code 6 chiffres) ---
REGISTRATION_CODE_EXPIRES_MINUTES=15
REGISTRATION_MAX_VERIFY_ATTEMPTS=5
# En développement uniquement : true = log le code en clair dans les logs serveur (sans SMTP utile pour debug)
REGISTRATION_LOG_CODE_IN_DEV=false

# --- Seed admin (npm run seed:admin) — ne pas réutiliser en prod les mêmes valeurs que l’exemple ---
ADMIN_SEED_EMAIL=admin@unikin.cd
ADMIN_SEED_PASSWORD=123456

# --- Seed dev (hors production) : 1 agent + 1 étudiant si SEED_DEV_PASSWORD est défini ---
SEED_DEV_PASSWORD=123456

# --- KELPAY Mobile Money (Keccel) ---
# Endpoints côté Keccel (POST sauf solde) : définis dans src/kelpay/kelpay.constants.ts, PAS dans .env
#   POST https://pay.keccel.com/kelpay/v1/payment.asp
#   POST https://pay.keccel.com/kelpay/v1/checktransaction.asp
#   GET  https://pay.keccel.com/kelpay/v1/getbalance.asp  (solde ; non exposé par l’API Nest actuelle)
#
# Ici : identifiants marchand. Pas de webhook Kelpay vers ce backend : le statut est obtenu par polling
# checktransaction côté serveur. Remplir KELPAY_CALLBACK_* seulement si la passerelle exige une URL non vide.
# KELPAY_CALLBACK_URL       = URL complète (optionnel), ex. https://api.mondomaine.com/api/payments/callback
# KELPAY_CALLBACK_BASE_URL  = optionnel, ex. https://api.mondomaine.com (suffixée par KELPAY_CALLBACK_PATH)
KELPAY_USE_BASIC_AUTH=false

KELPAY_MERCHANT_CODE=CLUBGEI
KELPAY_TOKEN=8cbcd6cc-2fcd-48df-9315-76431ca3e0d9
KELPAY_USERNAME=clubgei
KELPAY_PASSWORD=Clubgei844$
KELPAY_PIN=1097

KELPAY_CALLBACK_URL=
KELPAY_CALLBACK_BASE_URL=
KELPAY_CALLBACK_PATH=/api/payments/callback
KELPAY_CURRENCY=CDF
KELPAY_POLL_INITIAL_DELAY_MS=3000
KELPAY_POLL_INTERVAL_MS=5000
KELPAY_POLL_MAX_DURATION_MS=60000
KELPAY_POLL_MAX_ATTEMPTS=3
