# Exemple de fichier docker-compose.override.yml
# Copiez ce fichier vers docker-compose.override.yml pour personnaliser votre environnement local
# Ce fichier sera automatiquement chargé par docker-compose

version: '3.8'

services:
  backend:
    environment:
      # Surcharger les variables d'environnement pour le développement local
      MIKROTIK_HOST: 192.168.1.1
      MIKROTIK_USER: admin
      MIKROTIK_PASSWORD: votre-mot-de-passe-local
      JWT_SECRET: secret-de-dev-local-seulement
    volumes:
      # Ajouter des volumes supplémentaires si nécessaire
      # - ./backend/custom-config:/app/config

  frontend:
    environment:
      # Variables d'environnement pour le frontend en développement
      VITE_API_URL: http://localhost:4000/api
    volumes:
      # Hot reload pour le frontend (si vous voulez modifier sans rebuild)
      # - ./frontend/src:/app/src
      # - ./frontend/public:/app/public
